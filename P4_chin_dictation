let mode = 'puzzle';
let score=0, level=1, streak=0, hp=100;
let puzzleSet='vocab', puzzleIdx=0, puzzleCorrect=0;
let dictSet='vocab',   dictIdx=0;
let hwSet='vocab',     hwIdx=0;
let hwDrawing=false, hwLX=0, hwLY=0;
let hwCanvas, hwCtx;
let dragPiece=null, touchPiece=null;
window._correctChars=[];

// ===== UTILS =====
function updateStats(){
  document.getElementById('scoreVal').textContent=score;
  document.getElementById('levelVal').textContent=level;
  document.getElementById('streakVal').textContent=streak;
  document.getElementById('hpText').textContent=`${hp} / 100`;
  const f=document.getElementById('hpFill');
  f.style.width=hp+'%';
  f.className='hp-fill'+(hp<30?' low':hp<60?' medium':'');
}
function addScore(pts){
  score+=pts; level=Math.floor(score/300)+1; streak++; updateStats();
}
function loseHP(n){
  hp=Math.max(0,hp-n); if(hp===0){hp=100;} streak=0; updateStats();
}
function showToast(msg,color){
  const card=document.getElementById('gameCard');
  const t=document.createElement('div');
  t.className='feedback-toast';
  t.style.color=color||'#fff';
  t.textContent=msg;
  card.appendChild(t);
  requestAnimationFrame(()=>{ t.classList.add('show'); });
  setTimeout(()=>t.remove(),1550);
}
function speakWord(text){
  if(!window.speechSynthesis)return;
  window.speechSynthesis.cancel();
  const u=new SpeechSynthesisUtterance(text);
  u.lang='zh-HK'; u.rate=0.82; u.pitch=1.05;
  const v=window.speechSynthesis.getVoices();
  const pref=v.find(x=>x.lang==='zh-HK')||v.find(x=>x.lang==='zh-TW')||v.find(x=>x.lang.startsWith('zh'));
  if(pref)u.voice=pref;
  window.speechSynthesis.speak(u);
}
if(window.speechSynthesis){
  window.speechSynthesis.getVoices();
  window.speechSynthesis.onvoiceschanged=()=>window.speechSynthesis.getVoices();
}

// ===== MODE SWITCHING =====
function setMode(m){
  mode=m;
  ['puzzle','dictation','handwrite'].forEach(x=>{
    document.getElementById('tab'+x.charAt(0).toUpperCase()+x.slice(1))
      .classList.toggle('active',x===m);
  });
  render();
}
function render(){
  if(mode==='puzzle')renderPuzzle();
  else if(mode==='dictation')renderDictation();
  else renderHandwrite();
}

// ===== SET PILLS HTML =====
function pillsHTML(activeKey,fn){
  return Object.entries(WORD_SETS).map(([k,v])=>
    `<button class="set-pill${k===activeKey?' active':''}" onclick="${fn}('${k}')">${v.label}</button>`
  ).join('');
}
function progressHTML(idx,total){
  const pct=total?Math.round(idx/total*100):0;
  return `<div class="progress-row">
    <span>第 ${idx+1} / ${total} 題</span>
    <div class="progress-track"><div class="progress-fill" style="width:${pct}%"></div></div>
    <span>${pct}%</span>
  </div>`;
}

// ===== PLAY BUTTON =====
function playBtnHTML(id,onclick){
  return `<button class="play-ring" id="${id}" onclick="${onclick}" aria-label="播放讀音">🔊</button>
  <p style="text-align:center;font-size:var(--text-xs);color:var(--color-text-muted);margin-bottom:var(--space-4)">可重複播放</p>`;
}
function setPlaying(id,bool){
  const b=document.getElementById(id);
  if(b)b.classList.toggle('playing',bool);
}
function playSpeech(text,btnId){
  setPlaying(btnId,true);
  speakWord(text);
  const t=setInterval(()=>{ if(!window.speechSynthesis.speaking){clearInterval(t);setPlaying(btnId,false);} },200);
}

// ===== PUZZLE MODE =====
function renderPuzzle(){
  const items=WORD_SETS[puzzleSet].items;
  if(puzzleIdx>=items.length)puzzleIdx=0;
  puzzleCorrect=0;
  const ch=items[puzzleIdx];
  const chars=ch.char.split('');
  window._correctChars=chars;
  // distractors
  const pool=[...new Set(WORD_SETS[puzzleSet].items.flatMap(i=>i.char.split('')))].filter(c=>!chars.includes(c));
  const nd=Math.min(5,Math.max(2,7-chars.length));
  const mixed=[...chars,...pool.sort(()=>Math.random()-.5).slice(0,nd)].sort(()=>Math.random()-.5);
  const slots=chars.map((c,i)=>`
    <div class="puzzle-slot" id="pslot_${i}"
      ondragover="ev.preventDefault()" ondrop="dropPiece(event,${i})" ontouchend="touchDropPuzzle(event,${i})">
      <span id="pslotC_${i}"></span><span class="slot-num">${i+1}</span>
    </div>`).join('');
  const pieces=mixed.map((p,i)=>`
    <div class="puzzle-piece" id="pp_${i}" draggable="true"
      ondragstart="dragStart(event,'${p}',${i})"
      ontouchstart="touchStartPiece(event,'${p}',${i})">${p}</div>`).join('');
  document.getElementById('gameCard').innerHTML=`
    <div class="set-pills">${pillsHTML(puzzleSet,'switchPuzzleSet')}</div>
    ${progressHTML(puzzleIdx,items.length)}
    ${playBtnHTML('playBtnP',`playSpeech('${ch.char}','playBtnP')`)}
    <p style="text-align:center;font-size:var(--text-sm);color:var(--color-text-muted);margin-bottom:var(--space-4)">
      聽清楚後，將文字拖入正確位置 👇
    </p>
    <div class="puzzle-slots">${slots}</div>
    <div style="font-size:var(--text-xs);color:var(--color-text-muted);text-align:center;margin-bottom:var(--space-3)">可用字：</div>
    <div class="puzzle-pieces">${pieces}</div>
    <div class="btn-row">
      <button class="btn btn-ghost" onclick="renderPuzzle()">重置</button>
      <button class="btn btn-ghost" onclick="revealPuzzle()">👁 答案</button>
      <button class="btn btn-ghost" onclick="nextPuzzle()">下一題 ⏭</button>
    </div>
    <div id="puzzleReveal" style="text-align:center;font-size:1.6em;font-family:var(--font-display);font-weight:900;color:var(--color-primary);margin-top:var(--space-4);min-height:30px"></div>
  `;
  setTimeout(()=>playSpeech(ch.char,'playBtnP'),500);
}
function switchPuzzleSet(k){puzzleSet=k;puzzleIdx=0;renderPuzzle();}
function nextPuzzle(){
  const l=WORD_SETS[puzzleSet].items.length;
  puzzleIdx=(puzzleIdx+1)%l; renderPuzzle();
}
function revealPuzzle(){
  const ans=WORD_SETS[puzzleSet].items[puzzleIdx].char;
  document.getElementById('puzzleReveal').textContent='答案：'+ans;
}
function dragStart(e,p,i){dragPiece={p,i};e.dataTransfer.setData('text',p);}
function touchStartPiece(e,p,i){touchPiece={p,i};}
function dropPiece(e,si){e.preventDefault();if(!dragPiece)return;placePiece(dragPiece.p,dragPiece.i,si);dragPiece=null;}
function touchDropPuzzle(e,si){if(!touchPiece)return;placePiece(touchPiece.p,touchPiece.i,si);touchPiece=null;}
function placePiece(p,pi,si){
  const correct=window._correctChars;
  const slotEl=document.getElementById('pslot_'+si);
  const cEl=document.getElementById('pslotC_'+si);
  const pieEl=document.getElementById('pp_'+pi);
  if(!slotEl||!cEl||!pieEl)return;
  if(slotEl.dataset.filled==='1')return;
  if(p===correct[si]){
    cEl.textContent=p; slotEl.classList.add('filled'); slotEl.dataset.filled='1';
    pieEl.classList.add('used'); puzzleCorrect++;
    if(puzzleCorrect===correct.length){
      const ans=WORD_SETS[puzzleSet].items[puzzleIdx].char;
      const pts=80+streak*12;
      addScore(pts); updateStats();
      showToast(`✅ ${ans}
+${pts}分`,'#fff');
      setTimeout(nextPuzzle,1600);
    }
  } else {
    slotEl.classList.add('wrong'); setTimeout(()=>slotEl.classList.remove('wrong'),400);
    loseHP(8); updateStats();
    showToast('再試試！','#f4a261');
  }
}

// ===== DICTATION MODE =====
function renderDictation(){
  const items=WORD_SETS[dictSet].items;
  if(dictIdx>=items.length)dictIdx=0;
  document.getElementById('gameCard').innerHTML=`
    <div class="set-pills">${pillsHTML(dictSet,'switchDictSet')}</div>
    ${progressHTML(dictIdx,items.length)}
    ${playBtnHTML('playBtnD',`playSpeech('${items[dictIdx].char}','playBtnD')`)}
    <div class="dict-wrap">
      <p class="dict-note">聆聽後在下方輸入，按 Enter 或「核對」</p>
      <input class="dict-input" id="dictInput" type="text" placeholder="輸入答案…"
        autocomplete="off" autocorrect="off" spellcheck="false"
        onkeydown="if(event.key==='Enter')checkDict()"/>
      <div class="dict-result" id="dictResult"></div>
      <div class="answer-box" id="answerBox"></div>
    </div>
    <div class="btn-row">
      <button class="btn btn-primary" onclick="checkDict()">核對答案</button>
      <button class="btn btn-ghost" onclick="showDictAnswer()">👁 答案</button>
      <button class="btn btn-ghost" onclick="nextDict()">下一題 ⏭</button>
    </div>
  `;
  setTimeout(()=>playSpeech(items[dictIdx].char,'playBtnD'),500);
}
function switchDictSet(k){dictSet=k;dictIdx=0;renderDictation();}
function checkDict(){
  const items=WORD_SETS[dictSet].items;
  const ch=items[dictIdx];
  const inp=document.getElementById('dictInput');
  const res=document.getElementById('dictResult');
  const ans=inp.value.trim();
  if(!ans){res.textContent='請先輸入答案';return;}
  if(ans===ch.char){
    inp.classList.add('correct');inp.classList.remove('wrong');
    const pts=70+streak*10; addScore(pts); updateStats();
    res.innerHTML=`<span style="color:var(--color-success)">✅ 正確！</span>`;
    document.getElementById('answerBox').textContent='';
    showToast(`答對！
+${pts}分`,'#fff');
    setTimeout(nextDict,1500);
  } else {
    inp.classList.add('wrong');inp.classList.remove('correct');
    loseHP(10); updateStats();
    // char-by-char feedback
    let fb='';
    for(let i=0;i<Math.max(ans.length,ch.char.length);i++){
      const ok=ans[i]===ch.char[i];
      fb+=`<span style="color:var(--color-${ok?'success':'error'})">${ch.char[i]||''}</span>`;
    }
    res.innerHTML=`❌ 正確：${fb}`;
    document.getElementById('answerBox').textContent=ch.char;
  }
}
function showDictAnswer(){
  const ch=WORD_SETS[dictSet].items[dictIdx];
  document.getElementById('answerBox').textContent=ch.char;
}
function nextDict(){
  const l=WORD_SETS[dictSet].items.length;
  dictIdx=(dictIdx+1)%l; renderDictation();
}

// ===== HANDWRITE MODE =====
function renderHandwrite(){
  const items=WORD_SETS[hwSet].items;
  if(hwIdx>=items.length)hwIdx=0;
  const ch=items[hwIdx];
  const boxesHTML=ch.char.split('').map((_,i)=>
    `<div class="hw-char" id="hwc_${i}">?</div>`).join('');
  document.getElementById('gameCard').innerHTML=`
    <div class="set-pills">${pillsHTML(hwSet,'switchHwSet')}</div>
    ${progressHTML(hwIdx,items.length)}
    ${playBtnHTML('playBtnHW',`playSpeech('${ch.char}','playBtnHW')`)}
    <p style="text-align:center;font-size:var(--text-sm);color:var(--color-text-muted);margin-bottom:var(--space-2)">
      聽完後在下方書寫，完成後對答案
    </p>
    <canvas id="hwCanvas" width="340" height="200"></canvas>
    <div class="hw-chars">${boxesHTML}</div>
    <div class="hw-meaning" id="hwMeaning"></div>
    <div class="btn-row">
      <button class="btn btn-ghost" onclick="clearHW()">清除</button>
      <button class="btn btn-primary" onclick="revealHW()">✅ 對答案</button>
      <button class="btn btn-ghost" onclick="nextHW()">下一題 ⏭</button>
    </div>
  `;
  hwCanvas=document.getElementById('hwCanvas');
  hwCtx=hwCanvas.getContext('2d');
  setupHWEvents();
  setTimeout(()=>playSpeech(ch.char,'playBtnHW'),500);
}
function setupHWEvents(){
  const getPos=(e)=>{
    const r=hwCanvas.getBoundingClientRect();
    const sx=hwCanvas.width/r.width, sy=hwCanvas.height/r.height;
    const s=e.touches?e.touches[0]:e;
    return [(s.clientX-r.left)*sx,(s.clientY-r.top)*sy];
  };
  hwCanvas.onmousedown=hwCanvas.ontouchstart=(e)=>{e.preventDefault();hwDrawing=true;[hwLX,hwLY]=getPos(e);};
  hwCanvas.onmousemove=hwCanvas.ontouchmove=(e)=>{
    e.preventDefault();if(!hwDrawing)return;
    const [x,y]=getPos(e);
    hwCtx.beginPath();hwCtx.moveTo(hwLX,hwLY);hwCtx.lineTo(x,y);
    hwCtx.strokeStyle=getComputedStyle(document.documentElement).getPropertyValue('--color-primary').trim()||'#01696f';
    hwCtx.lineWidth=11;hwCtx.lineCap='round';hwCtx.stroke();
    [hwLX,hwLY]=[x,y];
  };
  hwCanvas.onmouseup=hwCanvas.ontouchend=()=>hwDrawing=false;
}
function clearHW(){
  if(hwCtx)hwCtx.clearRect(0,0,hwCanvas.width,hwCanvas.height);
  const ch=WORD_SETS[hwSet].items[hwIdx];
  ch.char.split('').forEach((_,i)=>{
    const el=document.getElementById('hwc_'+i);
    if(el){el.textContent='?';el.classList.remove('revealed');}
  });
  document.getElementById('hwMeaning').textContent='';
}
function revealHW(){
  const ch=WORD_SETS[hwSet].items[hwIdx];
  ch.char.split('').forEach((c,i)=>{
    const el=document.getElementById('hwc_'+i);
    if(el){el.textContent=c;el.classList.add('revealed');}
  });
  document.getElementById('hwMeaning').textContent=ch.meaning;
}
function switchHwSet(k){hwSet=k;hwIdx=0;renderHandwrite();}
function nextHW(){
  const l=WORD_SETS[hwSet].items.length;
  hwIdx=(hwIdx+1)%l; renderHandwrite();
}

// ===== THEME TOGGLE =====
(function(){
  const btn=document.querySelector('[data-theme-toggle]');
  const root=document.documentElement;
  let theme=matchMedia('(prefers-color-scheme:dark)').matches?'dark':'light';
  root.setAttribute('data-theme',theme);
  const moonIcon='<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>';
  const sunIcon='<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>';
  function update(){btn.innerHTML=theme==='dark'?sunIcon:moonIcon;}
  update();
  btn.addEventListener('click',()=>{
    theme=theme==='dark'?'light':'dark';
    root.setAttribute('data-theme',theme);
    update();
  });
})();

// ===== START =====
updateStats();
render();
</script>
</body>
</html>
