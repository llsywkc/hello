<style>
/* ===== TOKENS ===== */
:root,[data-theme="light"]{
  --color-bg:#f7f6f2;--color-surface:#f9f8f5;--color-surface-2:#fbfbf9;
  --color-surface-offset:#f3f0ec;--color-border:#d4d1ca;--color-divider:#dcd9d5;
  --color-text:#28251d;--color-text-muted:#7a7974;--color-text-faint:#bab9b4;
  --color-primary:#01696f;--color-primary-hover:#0c4e54;
  --color-success:#437a22;--color-error:#a12c7b;
  --color-gold:#d19900;--color-orange:#da7101;
  --shadow-sm:0 1px 3px oklch(0.2 0.01 80/0.08);
  --shadow-md:0 4px 14px oklch(0.2 0.01 80/0.10);
  --shadow-lg:0 12px 36px oklch(0.2 0.01 80/0.14);
  --radius-sm:0.375rem;--radius-md:0.5rem;--radius-lg:0.75rem;--radius-xl:1rem;--radius-full:9999px;
  --space-1:.25rem;--space-2:.5rem;--space-3:.75rem;--space-4:1rem;--space-5:1.25rem;
  --space-6:1.5rem;--space-8:2rem;--space-10:2.5rem;--space-12:3rem;
  --text-xs:clamp(.75rem,.7rem + .25vw,.875rem);
  --text-sm:clamp(.875rem,.8rem + .35vw,1rem);
  --text-base:clamp(1rem,.95rem + .25vw,1.125rem);
  --text-lg:clamp(1.125rem,1rem + .75vw,1.5rem);
  --text-xl:clamp(1.5rem,1.2rem + 1.25vw,2.25rem);
  --font-display:"Noto Serif TC",serif;
  --font-body:"Noto Sans TC",sans-serif;
  --transition:.18s cubic-bezier(.16,1,.3,1);
}
[data-theme="dark"]{
  --color-bg:#171614;--color-surface:#1c1b19;--color-surface-2:#201f1d;
  --color-surface-offset:#22211f;--color-border:#393836;--color-divider:#262523;
  --color-text:#cdccca;--color-text-muted:#797876;--color-text-faint:#5a5957;
  --color-primary:#4f98a3;--color-primary-hover:#227f8b;
  --color-success:#6daa45;--color-error:#d163a7;
  --color-gold:#e8af34;--color-orange:#fdab43;
  --shadow-sm:0 1px 3px oklch(0 0 0/.22);
  --shadow-md:0 4px 14px oklch(0 0 0/.32);
  --shadow-lg:0 12px 36px oklch(0 0 0/.42);
}

/* ===== BASE ===== */
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{-webkit-text-size-adjust:none;text-size-adjust:none;-webkit-font-smoothing:antialiased;scroll-behavior:smooth}
body{min-height:100dvh;font-family:var(--font-body);font-size:var(--text-base);
  color:var(--color-text);background:var(--color-bg);transition:background var(--transition),color var(--transition)}
img,svg{display:block;max-width:100%}
button{cursor:pointer;background:none;border:none;font:inherit;color:inherit}

/* ===== LAYOUT ===== */
.app{display:flex;flex-direction:column;min-height:100dvh;max-width:680px;margin-inline:auto;padding:var(--space-4)}

/* ===== HEADER ===== */
.header{display:flex;align-items:center;justify-content:space-between;margin-bottom:var(--space-6)}
.logo{display:flex;align-items:center;gap:var(--space-3)}
.logo-mark{width:38px;height:38px}
.logo-text{font-family:var(--font-display);font-size:var(--text-lg);font-weight:700;line-height:1.15}
.logo-sub{font-size:var(--text-xs);color:var(--color-text-muted);font-family:var(--font-body)}
.theme-btn{width:38px;height:38px;border-radius:var(--radius-full);
  background:var(--color-surface);border:1px solid var(--color-border);
  display:flex;align-items:center;justify-content:center;
  transition:background var(--transition),border-color var(--transition);flex-shrink:0}
.theme-btn:hover{background:var(--color-surface-offset)}

/* ===== STATS ===== */
.stats{display:grid;grid-template-columns:repeat(3,1fr);gap:var(--space-3);margin-bottom:var(--space-5)}
.stat-card{background:var(--color-surface);border:1px solid var(--color-border);
  border-radius:var(--radius-lg);padding:var(--space-3) var(--space-4);
  box-shadow:var(--shadow-sm);text-align:center}
.stat-val{font-size:var(--text-xl);font-weight:900;font-family:var(--font-display);
  color:var(--color-primary);line-height:1}
.stat-lbl{font-size:var(--text-xs);color:var(--color-text-muted);margin-top:var(--space-1)}

/* ===== HP BAR ===== */
.hp-wrap{margin-bottom:var(--space-5)}
.hp-header{display:flex;justify-content:space-between;font-size:var(--text-xs);color:var(--color-text-muted);margin-bottom:var(--space-2)}
.hp-track{height:10px;background:var(--color-surface-offset);border-radius:var(--radius-full);overflow:hidden}
.hp-fill{height:100%;border-radius:var(--radius-full);background:var(--color-success);transition:width .5s,background .5s}
.hp-fill.medium{background:var(--color-orange)}
.hp-fill.low{background:var(--color-error)}

/* ===== MODE TABS ===== */
.mode-tabs{display:flex;gap:var(--space-2);margin-bottom:var(--space-5);
  background:var(--color-surface);border:1px solid var(--color-border);
  border-radius:var(--radius-xl);padding:var(--space-1)}
.mode-tab{flex:1;padding:var(--space-2) var(--space-3);border-radius:var(--radius-lg);
  font-size:var(--text-sm);font-weight:700;text-align:center;
  color:var(--color-text-muted);transition:all var(--transition)}
.mode-tab.active{background:var(--color-primary);color:#fff;box-shadow:var(--shadow-sm)}
.mode-tab:hover:not(.active){background:var(--color-surface-offset);color:var(--color-text)}

/* ===== GAME CARD ===== */
.game-card{background:var(--color-surface);border:1px solid var(--color-border);
  border-radius:var(--radius-xl);padding:var(--space-8);
  box-shadow:var(--shadow-md);min-height:420px;position:relative}

/* ===== SET PILLS ===== */
.set-pills{display:flex;gap:var(--space-2);flex-wrap:wrap;justify-content:center;margin-bottom:var(--space-5)}
.set-pill{padding:var(--space-1) var(--space-4);border-radius:var(--radius-full);
  font-size:var(--text-xs);font-weight:700;border:1.5px solid var(--color-border);
  background:var(--color-surface-offset);color:var(--color-text-muted);transition:all var(--transition)}
.set-pill.active{background:var(--color-primary);border-color:var(--color-primary);color:#fff}
.set-pill:hover:not(.active){border-color:var(--color-primary);color:var(--color-primary)}

.progress-row{display:flex;justify-content:space-between;align-items:center;
  font-size:var(--text-xs);color:var(--color-text-muted);margin-bottom:var(--space-4)}
.progress-track{flex:1;height:4px;background:var(--color-surface-offset);
  border-radius:var(--radius-full);overflow:hidden;margin-inline:var(--space-3)}
.progress-fill{height:100%;background:var(--color-primary);border-radius:var(--radius-full);transition:width .4s}

/* ===== PLAY BTN ===== */
.play-ring{width:80px;height:80px;border-radius:50%;
  background:var(--color-primary);color:#fff;font-size:1.8em;
  display:flex;align-items:center;justify-content:center;
  margin-inline:auto;margin-bottom:var(--space-4);
  box-shadow:var(--shadow-md);transition:transform var(--transition),box-shadow var(--transition)}
.play-ring:hover{transform:scale(1.06);box-shadow:var(--shadow-lg)}
.play-ring.playing{animation:pulse .9s infinite alternate}
@keyframes pulse{from{box-shadow:var(--shadow-md)}to{box-shadow:0 0 0 10px oklch(from var(--color-primary) l c h / .18)}}

/* ===== PUZZLE ===== */
.puzzle-slots{display:flex;justify-content:center;gap:var(--space-3);flex-wrap:wrap;
  min-height:88px;margin:var(--space-5) 0}
.puzzle-slot{width:76px;height:76px;border-radius:var(--radius-lg);
  border:2px dashed var(--color-border);background:var(--color-surface-offset);
  display:flex;align-items:center;justify-content:center;position:relative;
  font-size:1.9em;font-weight:900;font-family:var(--font-display);
  color:var(--color-text-faint);transition:all var(--transition)}
.puzzle-slot.filled{border-style:solid;border-color:var(--color-success);
  background:oklch(from var(--color-success) l c h / .08);
  color:var(--color-text);box-shadow:0 0 0 3px oklch(from var(--color-success) l c h / .2)}
.puzzle-slot.wrong{border-style:solid;border-color:var(--color-error);animation:shake .35s}
.slot-num{position:absolute;right:4px;bottom:3px;font-size:.55em;font-family:var(--font-body);
  color:var(--color-text-faint);font-weight:400}
.puzzle-pieces{display:flex;gap:var(--space-3);flex-wrap:wrap;justify-content:center;margin-bottom:var(--space-5)}
.puzzle-piece{padding:var(--space-3) var(--space-4);border-radius:var(--radius-lg);
  font-size:1.5em;font-weight:900;font-family:var(--font-display);
  background:oklch(from var(--color-primary) 0.9 0.04 192);
  border:2px solid oklch(from var(--color-primary) 0.7 0.08 192);
  color:var(--color-primary-hover);cursor:grab;user-select:none;
  transition:transform var(--transition),box-shadow var(--transition),opacity var(--transition)}
.puzzle-piece:hover{transform:translateY(-3px) scale(1.05);box-shadow:var(--shadow-md)}
.puzzle-piece.used{opacity:.25;pointer-events:none}

/* ===== DICTATION INPUT ===== */
.dict-wrap{text-align:center;margin:var(--space-5) 0}
.dict-note{font-size:var(--text-sm);color:var(--color-text-muted);margin-bottom:var(--space-4)}
.dict-input{width:100%;max-width:320px;text-align:center;font-size:1.8em;
  font-family:var(--font-display);font-weight:700;
  background:var(--color-surface-offset);color:var(--color-text);
  border:2px solid var(--color-border);border-radius:var(--radius-lg);
  padding:var(--space-3) var(--space-4);outline:none;transition:border-color var(--transition),box-shadow var(--transition)}
.dict-input:focus{border-color:var(--color-primary);box-shadow:0 0 0 3px oklch(from var(--color-primary) l c h / .15)}
.dict-input.correct{border-color:var(--color-success);background:oklch(from var(--color-success) l c h / .06)}
.dict-input.wrong{border-color:var(--color-error);background:oklch(from var(--color-error) l c h / .06)}
.dict-result{min-height:28px;font-size:var(--text-sm);font-weight:700;margin-top:var(--space-3)}
.answer-box{margin-top:var(--space-3);font-size:1.8em;font-family:var(--font-display);
  font-weight:900;color:var(--color-primary);letter-spacing:.05em}

/* ===== HANDWRITE CANVAS ===== */
#hwCanvas{display:block;margin:var(--space-4) auto;
  border:2px solid var(--color-border);border-radius:var(--radius-lg);
  background:var(--color-surface-offset);touch-action:none;cursor:crosshair}
.hw-chars{display:flex;gap:var(--space-3);justify-content:center;flex-wrap:wrap;margin-top:var(--space-4)}
.hw-char{width:58px;height:58px;border-radius:var(--radius-md);
  border:2px solid var(--color-border);background:var(--color-surface-offset);
  display:flex;align-items:center;justify-content:center;
  font-size:1.7em;font-family:var(--font-display);font-weight:900;
  color:var(--color-text-faint);transition:all var(--transition)}
.hw-char.revealed{border-color:var(--color-success);color:var(--color-text);
  background:oklch(from var(--color-success) l c h / .08);
  box-shadow:0 0 0 3px oklch(from var(--color-success) l c h / .18)}
.hw-meaning{font-size:var(--text-sm);color:var(--color-text-muted);
  text-align:center;margin-top:var(--space-3);min-height:20px}

/* ===== BUTTONS ===== */
.btn-row{display:flex;gap:var(--space-3);justify-content:center;flex-wrap:wrap;margin-top:var(--space-5)}
.btn{padding:var(--space-2) var(--space-5);border-radius:var(--radius-full);
  font-size:var(--text-sm);font-weight:700;transition:all var(--transition)}
.btn-primary{background:var(--color-primary);color:#fff}
.btn-primary:hover{background:var(--color-primary-hover);box-shadow:var(--shadow-sm)}
.btn-ghost{background:var(--color-surface-offset);color:var(--color-text-muted);
  border:1.5px solid var(--color-border)}
.btn-ghost:hover{background:var(--color-surface);color:var(--color-text);border-color:var(--color-text-muted)}

/* ===== FEEDBACK TOAST ===== */
.feedback-toast{position:absolute;top:50%;left:50%;
  transform:translate(-50%,-50%) scale(.9);opacity:0;
  background:var(--color-text);color:var(--color-bg);
  padding:var(--space-4) var(--space-6);border-radius:var(--radius-xl);
  font-weight:900;text-align:center;white-space:pre-line;z-index:20;
  pointer-events:none;font-size:var(--text-lg);line-height:1.4;
  box-shadow:var(--shadow-lg);transition:none}
.feedback-toast.show{animation:toastAnim 1.5s ease forwards}
@keyframes toastAnim{
  0%{opacity:0;transform:translate(-50%,-50%) scale(.85)}
  15%{opacity:1;transform:translate(-50%,-50%) scale(1.02)}
  70%{opacity:1;transform:translate(-50%,-50%) scale(1)}
  100%{opacity:0;transform:translate(-50%,-60%) scale(1.03)}
}
@keyframes shake{0%,100%{transform:translateX(0)}25%{transform:translateX(-7px)}75%{transform:translateX(7px)}}

/* ===== DARK MODE CANVAS ===== */
[data-theme="dark"] #hwCanvas,[data-theme="dark"] #hwCanvas{background:#2a2927}
[data-theme="dark"] .puzzle-piece{
  background:oklch(from var(--color-primary) 0.25 0.06 192);
  border-color:oklch(from var(--color-primary) 0.4 0.09 192);
  color:var(--color-primary)}

/* ===== RESPONSIVE ===== */
@media(max-width:480px){
  .stats{grid-template-columns:repeat(3,1fr)}
  .game-card{padding:var(--space-5)}
  .puzzle-slot{width:66px;height:66px;font-size:1.6em}
  .mode-tab{font-size:.7em;padding:var(--space-2) var(--space-2)}
}
</style>
</head>
